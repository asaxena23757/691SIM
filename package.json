{
  "name": "691sim",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "FRC Architecture Verifier - monorepo root",
  "scripts": {
    "build": "pnpm -r --filter=./packages/* run build && pnpm --filter @691sim/web run build",
    "dev": "pnpm -r --filter=./packages/* run dev",
    "dev:web": "pnpm --filter @691sim/web run dev",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "node ./node_modules/typescript/bin/tsc -b --pretty false"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/node": "^22.19.21",
    "eslint": "^9.18.0",
    "prettier": "^3.4.2",
    "tsup": "^8.5.1",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.19.1",
    "vitest": "^2.1.8"
  },
  "packageManager": "pnpm@9.15.0",
  "dependencies": {
  }
}
